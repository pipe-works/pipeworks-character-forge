# PipeWorks Character Forge — environment file (example)
#
# Install path on Luminal: /etc/pipeworks/character-forge/character-forge.env
# All variables are optional — defaults in src/pipeworks_character_forge/core/config.py
# apply when unset. The PIPEWORKS_FORGE_ prefix is required.

# Server bind (loopback only — nginx terminates TLS upstream).
PIPEWORKS_FORGE_SERVER_HOST=127.0.0.1
PIPEWORKS_FORGE_SERVER_PORT=8420

# Storage paths (absolute). Defaults already point here — listed for clarity.
PIPEWORKS_FORGE_RUNS_DIR=/srv/work/pipeworks/runtime/character-forge/runs
PIPEWORKS_FORGE_MODELS_DIR=/srv/work/pipeworks/runtime/character-forge/models

# Hugging Face access token. Required to download FLUX.2-klein-base-9B
# (gated by Black Forest Labs) on a fresh machine. Once weights are
# cached under MODELS_DIR a token is no longer required at runtime, but
# leaving it set lets the systemd unit refresh the cache automatically.
# Generate at https://huggingface.co/settings/tokens (read scope is enough).
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Diffusion model.
PIPEWORKS_FORGE_FLUX2_MODEL_ID=black-forest-labs/FLUX.2-klein-base-9B
PIPEWORKS_FORGE_DEVICE=cuda
PIPEWORKS_FORGE_TORCH_DTYPE=bfloat16

# Generation defaults (overridable per run from the UI).
PIPEWORKS_FORGE_DEFAULT_STEPS=28
PIPEWORKS_FORGE_DEFAULT_GUIDANCE=4.5

# VRAM tuning. CPU offload is required for FLUX.2-klein-base-9B on a
# 32 GiB card (RTX 5090) — the resident model fills VRAM before any
# activations. With offload, peak measured at 18.5 GiB / ~52 s per i2i.
# Set CPU_OFFLOAD=false only on cards with substantially more VRAM
# (A100 80 GB, H100, etc.) where the resident model leaves >10 GiB
# headroom.
PIPEWORKS_FORGE_ENABLE_ATTENTION_SLICING=true
PIPEWORKS_FORGE_ENABLE_MODEL_CPU_OFFLOAD=true

# Logging.
PIPEWORKS_FORGE_LOG_LEVEL=INFO
